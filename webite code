
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>VAPEALE — Luxury Vape Experience</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    --pink-50:#fff5f9;
    --pink-100:#ffe4ef;
    --pink-200:#ffc8de;
    --pink-300:#ff9dc4;
    --pink-500:#ff5fa2;
    --pink-700:#d63384;
    --white:#ffffff;
    --ink:#2a1a23;
    --muted:#7a5d6a;
    --shadow:0 20px 60px rgba(214,51,132,.18);
    --radius:18px;
  }
  html{scroll-behavior:smooth}
  body{
    font-family:'Inter',sans-serif;
    color:var(--ink);
    line-height:1.6;
    background:
      radial-gradient(1200px 800px at 10% 0%, #ffd6e7 0%, transparent 60%),
      radial-gradient(900px 700px at 90% 30%, #ffe4ef 0%, transparent 55%),
      radial-gradient(1000px 800px at 50% 100%, #ffc8de 0%, transparent 60%),
      linear-gradient(180deg,#fff5f9 0%,#ffffff 50%,#fff0f7 100%);
    background-attachment: fixed;
    min-height:100vh;
    overflow-x:hidden;
  }
  /* Decorative blurred blobs */
  body::before,body::after{
    content:"";position:fixed;border-radius:50%;filter:blur(120px);z-index:-1;pointer-events:none;
  }
  body::before{width:600px;height:600px;background:#ff9dc4;opacity:.45;top:-150px;left:-150px;animation:float 18s ease-in-out infinite}
  body::after{width:700px;height:700px;background:#ffc8de;opacity:.5;bottom:-200px;right:-200px;animation:float 22s ease-in-out infinite reverse}
  @keyframes float{0%,100%{transform:translate(0,0)}50%{transform:translate(60px,-40px)}}

  h1,h2,h3{font-family:'Cormorant Garamond',serif;font-weight:600;letter-spacing:-.5px;color:#3a1726}

  /* Navbar */
  .nav{
    position:sticky;top:0;z-index:50;
    display:flex;align-items:center;justify-content:space-between;
    padding:18px 6%;
    background:rgba(255,255,255,.55);
    backdrop-filter:blur(20px) saturate(140%);
    border-bottom:1px solid rgba(255,157,196,.25);
  }
  .logo{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:700;letter-spacing:6px;color:var(--pink-700)}
  .logo span{color:var(--ink)}
  .nav ul{display:flex;gap:34px;list-style:none}
  .nav a{color:var(--ink);text-decoration:none;font-size:14px;font-weight:500;letter-spacing:1px;text-transform:uppercase;transition:color .3s}
  .nav a:hover{color:var(--pink-700)}
  .cart-btn{background:linear-gradient(135deg,var(--pink-500),var(--pink-700));color:#fff;border:none;padding:10px 22px;border-radius:30px;font-size:13px;font-weight:600;letter-spacing:1px;cursor:pointer;box-shadow:var(--shadow);transition:transform .3s}
  .cart-btn:hover{transform:translateY(-2px)}

  /* Hero */
  .hero{
    display:grid;grid-template-columns:1.1fr 1fr;gap:60px;align-items:center;
    padding:80px 6% 100px;max-width:1400px;margin:0 auto;
  }
  .hero-text .tag{display:inline-block;padding:6px 16px;background:rgba(255,157,196,.2);color:var(--pink-700);border-radius:30px;font-size:12px;letter-spacing:2px;text-transform:uppercase;margin-bottom:20px}
  .hero-text h1{font-size:clamp(48px,7vw,88px);line-height:1;margin-bottom:24px}
  .hero-text h1 em{font-style:italic;color:var(--pink-700)}
  .hero-text p{font-size:18px;color:var(--muted);margin-bottom:34px;max-width:480px}
  .cta-group{display:flex;gap:16px;flex-wrap:wrap}
  .btn{padding:14px 32px;border-radius:40px;font-weight:600;text-decoration:none;font-size:14px;letter-spacing:1px;transition:all .3s;display:inline-block;cursor:pointer;border:none}
  .btn-primary{background:linear-gradient(135deg,var(--pink-500),var(--pink-700));color:#fff;box-shadow:var(--shadow)}
  .btn-primary:hover{transform:translateY(-3px);box-shadow:0 25px 70px rgba(214,51,132,.35)}
  .btn-ghost{background:rgba(255,255,255,.6);backdrop-filter:blur(10px);color:var(--ink);border:1px solid rgba(214,51,132,.2)}
  .btn-ghost:hover{background:#fff}

  .hero-image{position:relative}
  .hero-image img{width:100%;border-radius:var(--radius);box-shadow:0 40px 100px rgba(214,51,132,.25)}
  .hero-image::before{content:"";position:absolute;inset:-20px;background:linear-gradient(135deg,var(--pink-300),transparent);border-radius:30px;filter:blur(40px);z-index:-1}

  /* Section */
  section{padding:90px 6%;max-width:1400px;margin:0 auto}
  .section-head{text-align:center;margin-bottom:60px}
  .section-head .tag{display:inline-block;padding:6px 16px;background:rgba(255,157,196,.2);color:var(--pink-700);border-radius:30px;font-size:12px;letter-spacing:2px;text-transform:uppercase;margin-bottom:16px}
  .section-head h2{font-size:clamp(36px,5vw,56px);margin-bottom:14px}
  .section-head p{color:var(--muted);max-width:600px;margin:0 auto;font-size:17px}

  /* Categories */
  .categories{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:24px}
  .cat-card{
    background:rgba(255,255,255,.55);
    backdrop-filter:blur(18px) saturate(150%);
    border:1px solid rgba(255,255,255,.7);
    border-radius:var(--radius);
    padding:36px 24px;text-align:center;
    transition:transform .4s, box-shadow .4s;
    cursor:pointer;
  }
  .cat-card:hover{transform:translateY(-8px);box-shadow:var(--shadow)}
  .cat-icon{width:64px;height:64px;margin:0 auto 18px;background:linear-gradient(135deg,var(--pink-100),var(--pink-300));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:28px}
  .cat-card h3{font-size:22px;margin-bottom:6px}
  .cat-card p{color:var(--muted);font-size:14px}

  /* Products */
  .products{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:30px}
  .product{
    background:rgba(255,255,255,.65);
    backdrop-filter:blur(20px) saturate(150%);
    border:1px solid rgba(255,255,255,.8);
    border-radius:var(--radius);overflow:hidden;
    transition:transform .4s, box-shadow .4s;
  }
  .product:hover{transform:translateY(-10px);box-shadow:var(--shadow)}
  .product-img{aspect-ratio:1;overflow:hidden;background:var(--pink-50)}
  .product-img img{width:100%;height:100%;object-fit:cover;transition:transform .6s}
  .product:hover .product-img img{transform:scale(1.08)}
  .product-body{padding:22px}
  .product-body h3{font-size:22px;margin-bottom:6px}
  .product-body .meta{color:var(--muted);font-size:13px;margin-bottom:14px}
  .product-row{display:flex;align-items:center;justify-content:space-between}
  .price{font-size:22px;font-weight:600;color:var(--pink-700);font-family:'Cormorant Garamond',serif}
  .buy{background:var(--ink);color:#fff;border:none;padding:9px 18px;border-radius:30px;font-size:12px;letter-spacing:1px;cursor:pointer;text-transform:uppercase;transition:background .3s}
  .buy:hover{background:var(--pink-700)}

  /* Video */
  .video-wrap{
    position:relative;border-radius:24px;overflow:hidden;
    box-shadow:0 40px 100px rgba(214,51,132,.25);
    aspect-ratio:16/9;background:#000;
  }
  .video-wrap video{width:100%;height:100%;object-fit:cover;display:block}
  .video-overlay{position:absolute;inset:0;background:linear-gradient(180deg,transparent 60%,rgba(214,51,132,.35));pointer-events:none}

  /* About */
  .about{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
  .about-img{position:relative}
  .about-img img{width:100%;border-radius:var(--radius);box-shadow:var(--shadow)}
  .about h2{font-size:clamp(36px,5vw,52px);margin-bottom:20px}
  .about p{color:var(--muted);margin-bottom:16px;font-size:16px}
  .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:30px}
  .stat{text-align:center;padding:20px;background:rgba(255,255,255,.5);backdrop-filter:blur(10px);border-radius:14px;border:1px solid rgba(255,255,255,.7)}
  .stat strong{display:block;font-family:'Cormorant Garamond',serif;font-size:34px;color:var(--pink-700)}
  .stat span{font-size:12px;letter-spacing:1px;text-transform:uppercase;color:var(--muted)}

  /* Footer */
  footer{
    margin-top:80px;padding:60px 6% 30px;
    background:rgba(255,255,255,.45);
    backdrop-filter:blur(20px);
    border-top:1px solid rgba(255,157,196,.25);
  }
  .foot-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;max-width:1400px;margin:0 auto 40px}
  .foot-grid h4{font-family:'Cormorant Garamond',serif;font-size:20px;margin-bottom:16px;color:var(--ink)}
  .foot-grid a,.foot-grid p{color:var(--muted);text-decoration:none;font-size:14px;display:block;margin-bottom:8px}
  .foot-grid a:hover{color:var(--pink-700)}
  .copyright{text-align:center;padding-top:24px;border-top:1px solid rgba(255,157,196,.2);color:var(--muted);font-size:13px}

  /* Responsive */
  @media (max-width:860px){
    .hero,.about{grid-template-columns:1fr;gap:40px}
    .nav ul{display:none}
    .foot-grid{grid-template-columns:1fr 1fr}
    section{padding:60px 6%}
  }
</style>
</head>
